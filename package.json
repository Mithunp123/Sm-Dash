{
  "name": "sm-volunteers-dashboard",
  "version": "1.0.0",
  "description": "SM Volunteers Dashboard - Student Management System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "start:backend": "npm start --prefix backend"
  },
  "keywords": [
    "student-management",
    "volunteers",
    "dashboard",
    "react",
    "express",
    "typescript"
  ],
  "author": "SM Volunteers Team",
  "license": "PRIVATE",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
